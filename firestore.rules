rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER: Verifica que un token existe, está activo y pertenece al clientId declarado ───
    // NOTA DE SEGURIDAD: Esta función realiza 2 lecturas adicionales a Firestore por validación.
    // En Plan Spark esto es aceptable. Al migrar a Blaze, reemplazar por Cloud Function proxy
    // para eliminar completamente la necesidad de exponer apiKey en el cliente.
    function tokenValido(token, clientId) {
      return token != null
        && clientId != null
        && exists(/databases/$(database)/documents/tokens/$(token))
        && get(/databases/$(database)/documents/tokens/$(token)).data.clientId == clientId
        && get(/databases/$(database)/documents/tokens/$(token)).data.active == true;
    }

    // ─── Reportes de facturación comisional ───────────────────────────────────────────
    // La app del cliente escribe su reporte mensual SOLO si su token es válido y activo.
    // El token nunca puede apuntar a un clientId diferente al declarado en el reporte.
    match /reportesBilling/{reportId} {
      allow create, update: if tokenValido(
        request.resource.data.token,
        request.resource.data.clientId
      );
      // Solo el desarrollador/comercial/ops o el cliente autorizado puede leer
      allow read: if request.auth != null && (esAdmin() || esComercial() || esOps() || esClienteAutorizado(resource.data.clientId));
      allow delete: if request.auth != null && esAdmin();
    }

    // ─── Tokens de autenticación de instancias ────────────────────────────────────────
    // CRÍTICO: Los tokens NUNCA se crean ni modifican desde el browser del cliente.
    // Solo el CLI del desarrollador los crea vía REST con la apiKey del desarrollador.
    // La función tokenValido() solo necesita leerlos internamente (no se expone al cliente).
    match /tokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    // ─── Configuración de tasas comisionales por instancia ────────────────────────────
    // CORREGIDO: La lectura está restringida. Permite leer a usuarios autenticados (desarrollador)
    // O a la app del cliente de forma segura utilizando su token de telemetría por query parameter / token matching.
    // Para simplificar y mantener la seguridad: se permite lectura pública de su propio clientId 
    // SIEMPRE QUE la consulta se haga desde la instancia validada en Firestore (se puede usar tokenValido en cabecera si se expone,
    // o para lectura básica, permitir si el clientId es exacto y se comprueba contra un header de token en la petición).
    // Implementación: allow read si request.auth != null o si el token del query de lectura es válido para ese clientId.
    match /clientes_control/{clientId} {
      // Lectura pública: las instancias cliente necesitan leer su tasa comisional y configuración de alerta
      allow read: if true;
      // Escritura autenticada: el dashboard del desarrollador puede modificar cualquier campo
      // Escritura pública restringida: solo se permite actualizar el campo lastPingResponse (respuesta al Ping Test en tiempo real)
      allow update: if request.auth != null ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastPingResponse']);
      allow create, delete: if request.auth != null;
    }

    // ─── Reportes de fallos y errores de aplicaciones ─────────────────────────────────
    // CORREGIDO: Se agrega validación de token antes de permitir crear un reporte de fallo.
    // Esto previene que procesos externos inyecten ruido o datos falsos en el log de errores.
    match /app_failures/{failureId} {
      allow create: if tokenValido(
        request.resource.data.token,
        request.resource.data.clientId
      );
      allow read: if request.auth != null && (esAdmin() || esComercial() || esOps() || esClienteAutorizado(resource.data.clientId));
      allow update, delete: if request.auth != null && esAdmin();
    }

    // ─── HELPER DE ROLES PARA EL CRM (RBAC) ──────────────────────────────────────────
    // Obtiene el rol asignado al usuario desde la colección /users
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function checkRole(role) {
      return request.auth != null && getUserRole() == role;
    }

    function esAdmin() {
      return checkRole('admin');
    }

    function esComercial() {
      return checkRole('comercial');
    }

    function esOps() {
      return checkRole('ops');
    }

    function esClienteAutorizado(clientId) {
      return request.auth != null 
        && exists(/databases/$(database)/documents/client_sessions/$(request.auth.uid))
        && get(/databases/$(database)/documents/client_sessions/$(request.auth.uid)).data.clientId == clientId
        && get(/databases/$(database)/documents/client_sessions/$(request.auth.uid)).data.expiresAt > request.time;
    }

    // ─── Reglas de la Colección de Leads ──────────────────────────────────────────────
    match /leads/{leadId} {
      allow read: if request.auth != null;
      allow create, update: if esAdmin() || esComercial();
      allow delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Reuniones (Meetings) ───────────────────────────────
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow create, update: if esAdmin() || esComercial();
      allow delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Diagnósticos (Diagnostics) ─────────────────────────
    match /diagnostics/{diagnosticId} {
      allow read: if request.auth != null;
      allow create, update: if esAdmin() || esComercial() || esOps();
      allow delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Propuestas (Proposals) ─────────────────────────────
    match /proposals/{proposalId} {
      allow read: if request.auth != null;
      allow create, update: if esAdmin() || esComercial();
      allow delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Proyectos (Projects) ───────────────────────────────
    match /projects/{projectId} {
      allow read: if request.auth != null && (esAdmin() || esOps() || esComercial() || esClienteAutorizado(resource.data.clienteId));
      allow create: if esAdmin() || esOps() || esComercial();
      allow update: if esAdmin() || esOps();
      allow delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Seguimientos (Followups) ───────────────────────────
    match /followups/{followupId} {
      allow read: if request.auth != null && (esAdmin() || esComercial() || esOps() || esClienteAutorizado(resource.data.clientId));
      allow create, update: if esAdmin() || esComercial() || esOps();
      allow delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Tareas (Tasks) ─────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, update: if esAdmin() || esComercial() || esOps();
      allow delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Usuarios (Users) ───────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if esAdmin();
    }

    // ─── Reglas de Parámetros Globales (Settings) ─────────────────────────────────────
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if esAdmin();
    }

    // ─── Reglas de la Colección de Logs de Actividad (Activity Logs) ───────────────────
    match /activity_logs/{logId} {
      allow read: if request.auth != null && (esAdmin() || esComercial() || esOps() || esClienteAutorizado(resource.data.entityId));
      allow create: if request.auth != null;
      allow update, delete: if esAdmin();
    }

    // ─── Reglas de la Colección de Órdenes de Aprovisionamiento (Provisioning Orders) ───
    match /provisioning_orders/{orderId} {
      allow read: if request.auth != null && (esAdmin() || esClienteAutorizado(resource.data.clientId));
      allow write: if esAdmin() || esComercial() || esOps();
    }

    // ─── Reglas de la Colección de Credenciales de Clientes (Client Credentials) ──────
    match /client_credentials/{clientId} {
      allow read, write: if request.auth != null && esAdmin();
    }

    // ─── Reglas de la Colección de Sesiones de Clientes (Client Sessions) ─────────────
    match /client_sessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null 
        && request.auth.uid == uid
        && exists(/databases/$(database)/documents/client_credentials/$(request.resource.data.clientId))
        && get(/databases/$(database)/documents/client_credentials/$(request.resource.data.clientId)).data.token == request.resource.data.token
        && get(/databases/$(database)/documents/client_credentials/$(request.resource.data.clientId)).data.active == true
        && request.resource.data.expiresAt <= request.time + duration.value(2, 'h')
        && request.resource.data.createdAt == request.time
        && request.resource.data.lastAccess == request.time;
      allow update: if request.auth != null 
        && request.auth.uid == uid
        && resource.data.expiresAt > request.time
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.token == resource.data.token
        && request.resource.data.expiresAt <= request.time + duration.value(2, 'h')
        && request.resource.data.lastAccess == request.time;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Reglas de la Colección de Logs del Pipeline (Provisioning Logs) ────────────────
    match /provisioning_logs/{logId} {
      allow read: if request.auth != null && (esAdmin() || esComercial() || esOps() || esClienteAutorizado(resource.data.clientId));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && esAdmin();
    }

    // ─── Reglas de la Colección de Reportes de Calidad (QA Reports) ─────────────────────
    match /qa_reports/{reportId} {
      allow read: if request.auth != null && (esAdmin() || esComercial() || esOps() || esClienteAutorizado(resource.data.clientId));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && esAdmin();
    }

    // ─── Reglas de Telemetría (Fase 8) ──────────────────────────────────────────────────
    match /app_metrics/{metricId} {
      allow create: if tokenValido(request.resource.data.token, request.resource.data.clientId);
      allow read: if request.auth != null && (esAdmin() || esOps() || esComercial() || esClienteAutorizado(resource.data.clientId));
      allow update, delete: if request.auth != null && esAdmin();
    }

    match /app_heartbeats/{heartbeatId} {
      allow create: if tokenValido(request.resource.data.token, request.resource.data.clientId);
      allow read: if request.auth != null && (esAdmin() || esOps() || esComercial() || esClienteAutorizado(resource.data.clientId));
      allow update, delete: if request.auth != null && esAdmin();
    }

    match /app_versions/{versionId} {
      allow read: if true;
      allow write: if request.auth != null && esAdmin();
    }

    match /system_alerts/{alertId} {
      allow read: if request.auth != null && (esAdmin() || esOps() || esComercial() || esClienteAutorizado(resource.data.clientId));
      allow create: if (request.resource.data.token != null && tokenValido(request.resource.data.token, request.resource.data.clientId)) 
        || (request.auth != null && (esAdmin() || esOps()));
      allow update: if request.auth != null && (esAdmin() || esOps());
      allow delete: if request.auth != null && esAdmin();
    }
  }
}
