rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER: Verifica que un token existe, está activo y pertenece al clientId declarado ───
    // NOTA DE SEGURIDAD: Esta función realiza 2 lecturas adicionales a Firestore por validación.
    // En Plan Spark esto es aceptable. Al migrar a Blaze, reemplazar por Cloud Function proxy
    // para eliminar completamente la necesidad de exponer apiKey en el cliente.
    function tokenValido(token, clientId) {
      return token != null
        && clientId != null
        && exists(/databases/$(database)/documents/tokens/$(token))
        && get(/databases/$(database)/documents/tokens/$(token)).data.clientId == clientId
        && get(/databases/$(database)/documents/tokens/$(token)).data.active == true;
    }

    // ─── Reportes de facturación comisional ───────────────────────────────────────────
    // La app del cliente escribe su reporte mensual SOLO si su token es válido y activo.
    // El token nunca puede apuntar a un clientId diferente al declarado en el reporte.
    match /reportesBilling/{reportId} {
      allow create, update: if tokenValido(
        request.resource.data.token,
        request.resource.data.clientId
      );
      // Solo el desarrollador autenticado (dev-dashboard) puede leer y eliminar
      allow read, delete: if request.auth != null;
    }

    // ─── Tokens de autenticación de instancias ────────────────────────────────────────
    // CRÍTICO: Los tokens NUNCA se crean ni modifican desde el browser del cliente.
    // Solo el CLI del desarrollador los crea vía REST con la apiKey del desarrollador.
    // La función tokenValido() solo necesita leerlos internamente (no se expone al cliente).
    match /tokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    // ─── Configuración de tasas comisionales por instancia ────────────────────────────
    // CORREGIDO: La lectura se restringe. Un documento de configuración de cliente
    // no debe ser público — contiene su modo de facturación y tasas de comisión.
    // La app del cliente no necesita leer esto desde el browser; la config de facturación
    // se inyecta localmente en el .env.local durante el aprovisionamiento del CLI.
    match /clientes_control/{clientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Reportes de fallos y errores de aplicaciones ─────────────────────────────────
    // CORREGIDO: Se agrega validación de token antes de permitir crear un reporte de fallo.
    // Esto previene que procesos externos inyecten ruido o datos falsos en el log de errores.
    match /app_failures/{failureId} {
      allow create: if tokenValido(
        request.resource.data.token,
        request.resource.data.clientId
      );
      allow read, update, delete: if request.auth != null;
    }
  }
}
