# Configuración de Firebase del proyecto "coordinador" (prototipe-ecosistema-control).
# Copia este archivo a .env.local (ya está en .gitignore) y pega los valores
# reales obtenidos desde Firebase Console → Configuración del proyecto →
# General → "Tus apps" → SDK de Firebase (Config). Nunca commitees .env.local.

VITE_DEVELOPER_CENTRAL_API_KEY=
VITE_DEVELOPER_CENTRAL_AUTH_DOMAIN=
VITE_DEVELOPER_CENTRAL_PROJECT_ID=prototipe-ecosistema-control
VITE_DEVELOPER_CENTRAL_STORAGE_BUCKET=
VITE_DEVELOPER_CENTRAL_MESSAGING_SENDER_ID=
VITE_DEVELOPER_CENTRAL_APP_ID=
